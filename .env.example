# Auckland Transport API
AT_API_KEY=your_api_key_here
AT_BASE_URL=https://api.at.govt.nz/realtime/legacy

# Kafka (local Docker)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_STARTING_OFFSETS=latest

# Local demo backpressure. Spark ignores startingOffsets once a checkpoint
# exists, so this mainly controls the very first run or a replay after reset.
BRONZE_MAX_OFFSETS_PER_TRIGGER=5000
TRIP_UPDATES_MAX_OFFSETS_PER_TRIGGER=2000
VEHICLE_POSITIONS_MAX_OFFSETS_PER_TRIGGER=4000
SERVICE_ALERTS_MAX_OFFSETS_PER_TRIGGER=200

# Local Spark budget. Makefile reads these too.
SPARK_DRIVER_MEMORY=1280m
Q4_SPARK_DRIVER_MEMORY=1536m
SPARK_SQL_SHUFFLE_PARTITIONS=4

# Adaptive polling (seconds)
# Peak (06:00-09:00, 15:00-18:30): max resolution for rush hour
# Shoulder (09:00-15:00, 18:30-22:00): moderate
# Off-peak (22:00-06:00): maintain continuity, minimal API cost
# Alerts: service_alerts — fixed interval, independent of time-of-day
POLL_INTERVAL_PEAK=30
POLL_INTERVAL_SHOULDER=60
POLL_INTERVAL_OFFPEAK=300
POLL_INTERVAL_ALERTS=300

# Azure Event Hubs (cloud — fill in after Day 3)
# KAFKA_BOOTSTRAP_SERVERS=<namespace>.servicebus.windows.net:9093
# EVENTHUBS_CONNECTION_STRING=Endpoint=sb://...

# Local paths
BRONZE_OUTPUT_PATH=./data/bronze
CHECKPOINT_PATH=./data/checkpoints
